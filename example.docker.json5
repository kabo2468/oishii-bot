{
    url: 'https://misskey.io',
    apiKey: '',
    apiUrl: 'https://misskey.io/api',
    databaseUrl: 'postgresql://postgres:PASSWORD@db:5432/postgres',
    dbSSL: false,
    ownerUsernames: ['kabo'],
    post: {
        autoPostInterval: 60,
        tlPostProbability: 0.4,
        rateLimitSec: 60,
        rateLimitPost: 5,
    },
    mecab: {
        binPath: '/usr/bin/mecab',
        dicPath: '/usr/lib/x86_64-linux-gnu/mecab/dic/mecab-ipadic-neologd',
    },
    denyRoleIds: [],
    // NGワードの追加ソース（オプション）
    // ローカルファイルパス（相対/絶対）またはHTTP(S) URLを指定
    // 除外ワード（-プレフィックス）でデフォルトのNGワードを無効化可能
    // ngWordSources: ['./custom-ngwords.txt', 'https://example.com/ngwords.txt'],
}
